# Copy this file to `.env` and replace the placeholder values.
# Do not commit your real `.env` file with live secrets.

# Google Maps route lookup
GOOGLE_MAPS_API_KEY= AIzaSyAKq26rXsweFBwVdbkwJc810HU0ooQ-akQ

# Optional weather lookup
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Session derivation secret for fake trajectory generation
APP_TRAJECTORY_SECRET=replace_with_a_long_random_app_secret

# Storage key rotation
FAKE_DATA_SECRET_V1=replace_with_storage_secret_v1
# FAKE_DATA_SECRET_V2=replace_with_storage_secret_v2
FAKE_DATA_SECRET_CURRENT_VERSION=1

# Runtime controls
STRICT_FAKE_ONLY=1
ENABLE_VISUAL_OUTPUTS=0
HEADLESS_LOCAL_TEST=0
RUN_SELF_TEST=0

# Optional routing inputs
ORIGIN=RMIT Melbourne, Australia
DESTINATION=Deakin Burwood, Australia

# Output path
FAKE_DATA_PATH=encrypted_fake_points.bin

# Optional identifiers
USER_ID=123
TIMESTAMP=1700000000
